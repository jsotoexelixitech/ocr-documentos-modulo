# ── Build local (dev) ──────────────────────────────────────────────────────────
# Para desarrollo local no es necesario cambiar nada; los valores por defecto
# apuntan al backend en localhost.

# Base path Vite — prefijo con el que se sirve el front
# Local:       /
# cierrelmds:  /ocr/
VITE_APP_BASE=/

# URL de nexus-api (SSO, verify, bridge)
# Local:       http://localhost:3092
# cierrelmds:  https://cierrelmds.exelixitech.com/nexus-api
VITE_NEXUS_API_URL=http://localhost:3092

# API Key de empresa (opcional en dev)
VITE_NEXUS_API_KEY=
