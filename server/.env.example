# ─── Modulo OCR · Backend ────────────────────────────────────────────
# Copia este archivo a .env y completa los valores.

# Puerto en el que escucha el servidor (default 4001)
PORT=4001

# Origenes permitidos por CORS (* para abrir totalmente, recomendado en dev)
CORS_ORIGINS=*

# Tamano maximo permitido por archivo subido en MB
UPLOAD_MAX_SIZE_MB=25

# Limite del body JSON
JSON_BODY_LIMIT=1mb

# ─── Multi-tenant (Nexus) ─────────────────────────────────────────────
# Si true, todas las rutas /api requieren un nexus_token valido.
NEXUS_AUTH_ENABLED=true
# Mismo secret configurado en nexus-api (TENANT_TOKEN_SECRET).
# IMPORTANTE: debe coincidir exactamente con el de nexus-api.
TENANT_TOKEN_SECRET=
# Id del submodulo OCR en la BD de nexus (tabla submodulo). Necesario
# para impedir que un token emitido para otro submodulo sea aceptado.
NEXUS_EXPECTED_SUBMODULO_ID=17

# ─── Proveedor OCR ────────────────────────────────────────────────────
# mock | gemini
OCR_PROVIDER=gemini

# Google Gemini — obtener key en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo principal. Si falla, el provider hace fallback automatico:
# gemini-2.5-pro -> gemini-2.5-flash -> gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-pro

# Reintentos por modelo en errores transitorios (429, 5xx, timeout)
GEMINI_MAX_RETRIES=2
